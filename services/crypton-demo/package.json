{
  "name": "crypton-demo-site",
  "version": "1.0.0",
  "private": true,
  "description": "Minimal demo showing Login with Crypton (OAuth 2.0 authorization code flow)",
  "scripts": {
    "start": "node server.js",
    "client:start": "react-scripts start",
    "build:sdk": "npm --prefix ../../libs/crypton-sdk install && npm --prefix ../../libs/crypton-sdk run build",
    "client:build": "npm run build:sdk && react-scripts build"
  },
  "dependencies": {
    "@crypton/sdk": "file:../../libs/crypton-sdk",
    "cookie-parser": "^1.4.6",
    "express": "^4.18.2",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^13.5.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-scripts": "5.0.1",
    "web-vitals": "^2.1.4"
  },
  "proxy": "http://127.0.0.1:8090",
  "engines": {
    "node": ">=18"
  }
}
