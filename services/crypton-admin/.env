# crypton-admin React app environment
# For local dev the CRA proxy (package.json → "proxy") forwards API calls to
# http://127.0.0.1:8080, so leave this blank:
REACT_APP_IDENTITY_URL=

# Allow cloudflared tunnel host (disables webpack-dev-server DNS rebinding check)
# This is safe since cloudflared itself handles HTTPS and request origin validation
DANGEROUSLY_DISABLE_HOST_CHECK=true

# For cross-device / cloudflared tunnel testing set this to your tunnel URL:
# REACT_APP_IDENTITY_URL=https://your-tunnel.trycloudflare.com
