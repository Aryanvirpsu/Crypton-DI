# Crypton Admin — environment variables
#
# REACT_APP_API_BASE
#   Leave empty for local development (CRA proxy in package.json handles routing).
#   Set to the public HTTPS origin of your gateway for tunnel/remote/staging use.
#
#   Examples:
#     Local dev  : (unset or empty)
#     Tunnel demo: REACT_APP_API_BASE=https://your-tunnel.trycloudflare.com
#
# DANGEROUSLY_DISABLE_HOST_CHECK
#   Required when serving via cloudflared quick tunnels (avoids "Invalid Host header").
#
DANGEROUSLY_DISABLE_HOST_CHECK=true
