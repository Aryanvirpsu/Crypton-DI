# crypton-gateway environment configuration
# Copy to .env and adjust as needed.

# Port the gateway listens on
APP_PORT=8090

# URL of the crypton-identity service that the gateway proxies to.
# In local dev this is plain HTTP on localhost.
# In production / Docker this would be the internal service URL.
IDENTITY_URL=http://127.0.0.1:8080

# Log level: error | warn | info | debug | trace
RUST_LOG=info
