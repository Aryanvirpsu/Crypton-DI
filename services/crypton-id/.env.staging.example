# crypton-identity — STAGING environment template
# Copy to: services/crypton-identity/.env  (never commit the filled copy)
#
# Staging = dev branch, Cloudflare quick-tunnel, local Postgres/Redis via Docker.
# Run after: docker compose -f infra/docker-compose.yml up -d

APP_PORT=8080
DATABASE_URL=postgres://postgres:postgres@127.0.0.1:5432/crypton
REDIS_URL=redis://127.0.0.1:6379
RUST_LOG=info

# ── WebAuthn (MUST match the active Cloudflare tunnel URL) ────────────────────
# Get tunnel URL from: cloudflared tunnel --url http://localhost:3000
# Update both values every time a new tunnel is started.
WEBAUTHN_RP_NAME=Crypton Identity
WEBAUTHN_RP_ID=<subdomain>.trycloudflare.com
WEBAUTHN_ORIGIN=https://<subdomain>.trycloudflare.com

# ── JWT ───────────────────────────────────────────────────────────────────────
# 256-bit hex. Generate: openssl rand -hex 32
JWT_SECRET=<staging_jwt_secret_32_bytes_hex>

# ── OAuth demo client ─────────────────────────────────────────────────────────
OAUTH_CLIENT_ID=demo-site
OAUTH_CLIENT_SECRET=demo-secret-staging
OAUTH_REDIRECT_URIS=https://<subdomain>.trycloudflare.com/callback
FRONTEND_ORIGIN=https://<subdomain>.trycloudflare.com
