# crypton-identity — PRODUCTION environment template
# Copy to: services/crypton-identity/.env  (never commit the filled copy)
#
# Production = main branch, stable domain or Cloudflare tunnel.
# Passkeys enrolled on a given RP_ID are permanently bound to it —
# changing WEBAUTHN_RP_ID invalidates all existing registered devices.

APP_PORT=8080
DATABASE_URL=postgres://postgres:postgres@127.0.0.1:5432/crypton
REDIS_URL=redis://127.0.0.1:6379
RUST_LOG=warn

# ── WebAuthn ──────────────────────────────────────────────────────────────────
# CRITICAL: never change these after users have enrolled passkeys.
WEBAUTHN_RP_NAME=Crypton Identity
WEBAUTHN_RP_ID=<your-stable-domain.com>
WEBAUTHN_ORIGIN=https://<your-stable-domain.com>

# ── JWT ───────────────────────────────────────────────────────────────────────
# Must differ from staging. Generate: openssl rand -hex 32
JWT_SECRET=<production_jwt_secret_32_bytes_hex_CHANGE_THIS>

# ── OAuth ─────────────────────────────────────────────────────────────────────
OAUTH_CLIENT_ID=demo-site
OAUTH_CLIENT_SECRET=<production_oauth_secret_CHANGE_THIS>
OAUTH_REDIRECT_URIS=https://<your-stable-domain.com>/callback
FRONTEND_ORIGIN=https://<your-stable-domain.com>
