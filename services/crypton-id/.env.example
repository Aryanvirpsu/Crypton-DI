# crypton-identity environment — copy to .env and fill in values
# .env is gitignored; this file is the committed template.

APP_PORT=8080

# Postgres (docker-compose spins one up at localhost:5432)
DATABASE_URL=postgres://postgres:postgres@127.0.0.1:5432/crypton

# Redis (docker-compose spins one up at localhost:6379)
REDIS_URL=redis://127.0.0.1:6379

RUST_LOG=info

# ── WebAuthn ──────────────────────────────────────────────────────────────────
# WEBAUTHN_RP_ID must be a registrable domain suffix of WEBAUTHN_ORIGIN.
# The origin seen by the browser must match WEBAUTHN_ORIGIN exactly.
#
# ── Option A: Local dev with TLS (crypton.local) ─────────────────────────────
# Requires:
#   1. Hosts file entry:  127.0.0.1  crypton.local
#   2. Self-signed cert:  crypton.local.pem / crypton.local-key.pem in this dir
#      Generate with mkcert:  mkcert crypton.local
# The server serves the test UI at https://crypton.local:8080/test
#
# WEBAUTHN_RP_ID=crypton.local
# WEBAUTHN_ORIGIN=https://crypton.local:8080

# ── Option B: Cloudflare quick-tunnel (eduroam / cross-device) ───────────────
# Run ./dev-tunnel.ps1 to get a URL, then fill in the subdomain below.
# Restart the Rust server after changing these values.
# Test UI will be at https://<subdomain>.trycloudflare.com/test
#
# WEBAUTHN_RP_ID=<subdomain>.trycloudflare.com
# WEBAUTHN_ORIGIN=https://<subdomain>.trycloudflare.com

# ── Option C: Plain localhost (single-device only) ────────────────────────────
# Works because browsers treat localhost as a secure context.
# WebAuthn RP ID must be "localhost" for this to work.
#
# WEBAUTHN_RP_ID=localhost
# WEBAUTHN_ORIGIN=http://localhost:8080

# Uncomment exactly one block above, then set these:
WEBAUTHN_RP_ID=crypton.local
WEBAUTHN_ORIGIN=https://crypton.local:8080
WEBAUTHN_RP_NAME=Crypton Identity

# JWT secret — use a long random value in production
JWT_SECRET=change_me_to_a_long_random_secret
