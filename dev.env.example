# crypton dev environment -- example (copy to dev.env and fill in)
# Used by start-all.ps1 to populate environment variables for crypton-id.

# crypton-id identity backend
APP_PORT=8080
DATABASE_URL=postgres://postgres:postgres@127.0.0.1:5432/crypton
REDIS_URL=redis://127.0.0.1:6379
RUST_LOG=info
JWT_SECRET=<your-64-char-hex-secret>

# WebAuthn (localhost dev defaults -- change for tunnel/production)
# For cloudflared tunnel: set RP_ID and ORIGIN to your tunnel hostname
WEBAUTHN_RP_NAME=Crypton Identity
WEBAUTHN_RP_ID=localhost
WEBAUTHN_ORIGIN=http://localhost:3001

# OAuth / demo surface
OAUTH_CLIENT_ID=demo-site
OAUTH_CLIENT_SECRET=<change-in-prod>
OAUTH_REDIRECT_URIS=http://localhost:4000/callback
FRONTEND_ORIGIN=http://localhost:3001
